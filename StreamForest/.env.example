# ============================================================
# StreamForest - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your local paths:
#   cp .env.example .env
#
# All variables below can also be set via shell environment.
# Shell environment variables take precedence over .env values.
# ============================================================

# --- Required: Model Checkpoint ---
# Path to your StreamForest model checkpoint (HuggingFace format)
# Example: download from HuggingFace Hub or use your own trained checkpoint
CKPT_PATH=/path/to/your/StreamForest-Qwen2-7B

# --- Optional: Data Paths ---
# Path to the local data roots YAML file for benchmark datasets.
# If not set, the eval script will try to load data from HuggingFace Hub.
# See scripts/eval/local_data_roots.example.yaml for the format.
# STREAMFOREST_DATA_ROOTS_FILE=./scripts/eval/local_data_roots.yaml

# --- Optional: Evaluation Settings ---
# Maximum number of frames to sample from each video (default: 2048)
# MAX_FRAMES=2048

# Model name used for evaluation (default: streamforest)
# MODEL_NAME=streamforest

# Prompt template type (default: short_online_v2)
# TIME_MSG=short_online_v2

# Number of GPUs to use (default: auto-detect all available GPUs)
# NUM_GPUS=4

# Conversation template (default: qwen_2)
# CONV_TEMPLATE=qwen_2

# --- Optional: Cluster / SLURM ---
# Set to 0 to disable srun even if available (default: auto)
# USE_SRUN=0
# SLURM partition name (used when srun is enabled)
# SRUN_PARTITION=videop1

# --- Optional: HuggingFace ---
# HF_DATASETS_CACHE=/path/to/hf_cache
# HF_DATASETS_OFFLINE=1
